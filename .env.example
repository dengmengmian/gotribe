# ============================================
# Gotribe 本地开发环境变量模板
# ============================================
# 用法：
#   cp .env.example .env
#   # 编辑 .env，填入你的密钥
#   docker-compose up -d

# --------------------------------------------
# 数据库（PostgreSQL）
# --------------------------------------------
POSTGRES_USER=gotribe
POSTGRES_PASSWORD=gotribe_dev
POSTGRES_DB=gotribe
POSTGRES_PORT=5432

# --------------------------------------------
# Redis
# --------------------------------------------
REDIS_PORT=6379

# --------------------------------------------
# 公用上传配置
# ToC API 和 Admin 共享这组资源存储配置。
# --------------------------------------------
GOTRIBE_UPLOAD_PROVIDER=qiniu
GOTRIBE_UPLOAD_ACCESS_KEY=replace-me
GOTRIBE_UPLOAD_SECRET_KEY=replace-me
GOTRIBE_UPLOAD_ENDPOINT=replace-me
GOTRIBE_UPLOAD_BUCKET=replace-me
GOTRIBE_UPLOAD_REGION=
GOTRIBE_UPLOAD_CDN_DOMAIN=https://cdn.example.com/

# --------------------------------------------
# ToC API 端口
# --------------------------------------------
API_PORT=8080

# --------------------------------------------
# Admin 后台端口
# --------------------------------------------
ADMIN_PORT=8088

# --------------------------------------------
# ToC API JWT 密钥（至少 32 位，不能是占位值）
# 示例：openssl rand -base64 32
# --------------------------------------------
GOTRIBE_AUTH_SECRET=replace-with-your-own-long-random-secret-min-32-chars

# --------------------------------------------
# ToC API 默认项目 ID
# --------------------------------------------
GOTRIBE_APP_DEFAULT_PROJECT_ID=1

# --------------------------------------------
# Admin 后台配置
# 这些值会被 docker-compose 注入 gotribe-admin 容器。
# --------------------------------------------

# Admin JWT 密钥（至少 32 位）
# 示例：openssl rand -base64 32
JWT_KEY=replace-with-your-own-long-random-secret-min-32-chars

# 是否同步更新已存在的内置菜单/API/角色 seed。
# 首次初始化或明确需要同步内置定义时可设为 true；日常建议 false，避免覆盖后台手工调整。
GOTRIBE_ADMIN_SYNC_SEED_DATA=false
