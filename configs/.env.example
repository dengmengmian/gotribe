# =========================================================================
# GoTribe 环境变量示例
# -------------------------------------------------------------------------
# 环境变量会覆盖 configs/config.yaml 中的同名配置。
# 命名规则：配置路径转大写，并用 GOTRIBE_ 作为前缀。
# 例如 admin.sync_seed_data => GOTRIBE_ADMIN_SYNC_SEED_DATA。
# =========================================================================

# =========================================================================
# 公用配置：ToC API 和 Admin 都会使用
# =========================================================================

# 应用名称，用于日志、监控和部分缓存 key 前缀。
GOTRIBE_APP_NAME=gotribe-api
# 运行环境，可选 development / production。
GOTRIBE_APP_ENV=development
# ToC API 默认项目 ID。请求未传 X-Project-ID 时使用。
GOTRIBE_APP_DEFAULT_PROJECT_ID=1

# 数据库类型。当前项目主线使用 postgres。
GOTRIBE_DATABASE_TYPE=postgres
# 数据库主机。
GOTRIBE_DATABASE_HOST=localhost
# 数据库端口。
GOTRIBE_DATABASE_PORT=5432
# 数据库账号。
GOTRIBE_DATABASE_USERNAME=replace-me
# 数据库密码。
GOTRIBE_DATABASE_PASSWORD=replace-me
# 数据库名。
GOTRIBE_DATABASE_DATABASE=replace-me
# PostgreSQL DSN 附加参数。
GOTRIBE_DATABASE_QUERY=connect_timeout=10 TimeZone=Asia/Shanghai
# 是否打印 SQL 日志。开发环境建议开启，生产环境建议关闭。
GOTRIBE_DATABASE_LOG_MODE=true
# PostgreSQL SSL 模式，本地一般为 disable。
GOTRIBE_DATABASE_SSLMODE=disable
# 最大空闲连接数。
GOTRIBE_DATABASE_MAX_IDLE_CONNS=10
# 最大打开连接数。
GOTRIBE_DATABASE_MAX_OPEN_CONNS=30
# 空闲连接最大保留时间，单位分钟。
GOTRIBE_DATABASE_CONN_MAX_IDLE_TIME_MINS=10
# 连接最大复用时间，单位分钟。
GOTRIBE_DATABASE_CONN_MAX_LIFETIME_MINS=30

# Redis 地址，格式 host:port。
GOTRIBE_REDIS_ADDR=127.0.0.1:6379
# Redis 密码，无密码留空。
GOTRIBE_REDIS_PASSWORD=
# Redis DB 编号。
GOTRIBE_REDIS_DB=0
# Redis 连接池大小。
GOTRIBE_REDIS_POOL_SIZE=10
# 默认缓存 TTL，单位分钟。
GOTRIBE_REDIS_DEFAULT_CACHE_TTL_MINS=5

# 公用上传供应商，ToC API 和 Admin 都复用这一套资源存储配置。
GOTRIBE_UPLOAD_PROVIDER=qiniu
# 上传供应商 Access Key。
GOTRIBE_UPLOAD_ACCESS_KEY=replace-me
# 上传供应商 Secret Key。
GOTRIBE_UPLOAD_SECRET_KEY=replace-me
# 上传供应商 endpoint。
GOTRIBE_UPLOAD_ENDPOINT=replace-me
# 上传 bucket。
GOTRIBE_UPLOAD_BUCKET=replace-me
# 上传区域，供应商需要时填写。
GOTRIBE_UPLOAD_REGION=
# 上传资源访问域名，Admin 资源管理和未来 ToC API 上传都会使用。
GOTRIBE_UPLOAD_CDN_DOMAIN=https://cdn.example.com/

# 是否启用 /metrics 指标。
GOTRIBE_OBSERVABILITY_METRICS_ENABLED=true
# 是否生成并透传 trace 信息。
GOTRIBE_OBSERVABILITY_TRACING_ENABLED=true

# =========================================================================
# ToC API 专属配置：cmd/api 使用
# =========================================================================

# ToC API HTTP 监听端口。
GOTRIBE_SERVER_PORT=8080
# 读取请求超时时间，单位秒。
GOTRIBE_SERVER_READ_TIMEOUT_SECONDS=10
# 写响应超时时间，单位秒。
GOTRIBE_SERVER_WRITE_TIMEOUT_SECONDS=15
# 空闲连接超时时间，单位秒。
GOTRIBE_SERVER_IDLE_TIMEOUT_SECONDS=60
# 优雅退出超时时间，单位秒。
GOTRIBE_SERVER_SHUTDOWN_TIMEOUT_SECONDS=10

# ToC API JWT issuer。
GOTRIBE_AUTH_ISSUER=gotribe
# ToC API JWT 密钥，至少 32 位，不能使用占位值。
GOTRIBE_AUTH_SECRET=replace-with-your-own-long-random-secret-min-32-chars
# Access Token 有效期，单位分钟。
GOTRIBE_AUTH_ACCESS_TOKEN_TTL_MINUTES=120
# Refresh Token 有效期，单位小时。
GOTRIBE_AUTH_REFRESH_TOKEN_TTL_HOURS=168

# 是否开启 ToC API 限流。
GOTRIBE_RATE_LIMIT_ENABLED=true
# 登录/刷新类接口每分钟限制。
GOTRIBE_RATE_LIMIT_AUTH_PER_MINUTE=10
# 普通 API 每分钟限制。
GOTRIBE_RATE_LIMIT_API_PER_MINUTE=120
# 用户事件上报类接口每分钟限制。
GOTRIBE_RATE_LIMIT_EVENT_PER_MINUTE=60

# =========================================================================
# Admin 专属配置：cmd/admin 使用
# =========================================================================

# Admin 运行模式，debug / release。
GOTRIBE_ADMIN_MODE=debug
# Admin 监听地址。
GOTRIBE_ADMIN_HOST=0.0.0.0
# Admin 后端端口。
GOTRIBE_ADMIN_PORT=8089
# Admin API URL 前缀。实际接口形如 /api/admin/info。
GOTRIBE_ADMIN_URL_PATH_PREFIX=api
# 是否执行初始化数据 seed。
GOTRIBE_ADMIN_INIT_DATA=true
# 是否同步更新已存在的内置 seed 数据。
# 仅建议第一次熟悉系统、或明确要同步内置菜单/API/角色定义时临时打开。
GOTRIBE_ADMIN_SYNC_SEED_DATA=false
# 是否启用 SQL migration。
GOTRIBE_ADMIN_ENABLE_MIGRATE=true
# 是否启用旧 OSS 开关。
GOTRIBE_ADMIN_ENABLE_OSS=false

# Admin 日志目录。
GOTRIBE_ADMIN_LOGS_PATH=logs
# Admin JWT realm。
GOTRIBE_ADMIN_JWT_REALM=gotribe-admin
# Admin JWT 密钥，至少 32 位，生产环境必须替换。
GOTRIBE_ADMIN_JWT_KEY=replace-with-your-own-admin-jwt-secret-min-32-chars
# Admin access token 有效期，单位小时。
GOTRIBE_ADMIN_JWT_TIMEOUT=12
# Admin token 最大刷新窗口，单位小时。
GOTRIBE_ADMIN_JWT_MAX_REFRESH=12

# Admin RBAC 模型文件路径。
GOTRIBE_ADMIN_CASBIN_MODEL_PATH=configs/rbac_model.conf
# Admin RBAC 模型外部覆盖路径。当前 Casbin 初始化会优先读取这个环境变量。
GOTRIBE_ADMIN_RBAC_MODEL=configs/rbac_model.conf
# Admin 前端静态文件目录。通常只在容器部署时覆盖。
GOTRIBE_ADMIN_WEB_DIST=/app/web/admin/dist

# 百度搜索资源平台推送 token。
GOTRIBE_ADMIN_BAIDU_PUSH_TOKEN=replace-me
